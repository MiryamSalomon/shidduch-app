# =============================================================================
# Shidduch Matchmaking System — Environment Variables
# =============================================================================
# Copy this file to .env and fill in real values before running.
#
#   cp .env.example .env
#
# NEVER commit .env to version control — it contains secrets.
# =============================================================================

# ---------------------------------------------------------------------------
# MongoDB Atlas Connection
# ---------------------------------------------------------------------------
# Full connection string for MongoDB Atlas (required for Vector Search).
# Format: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>
# For local development without vector search: mongodb://localhost:27017
MONGODB_URI=mongodb://localhost:27017

# Database name within the MongoDB cluster
MONGODB_DB_NAME=shidduch

# ---------------------------------------------------------------------------
# Authentication / Security
# ---------------------------------------------------------------------------
# Secret key used to sign JWT access tokens.
# Generate a strong random key: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=CHANGE_ME_TO_A_RANDOM_64_CHAR_HEX_STRING

# JWT access token lifetime in hours (default: 8 = one workday)
JWT_EXPIRY_HOURS=8

# ---------------------------------------------------------------------------
# OpenAI API
# ---------------------------------------------------------------------------
# API key from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# Embedding model — text-embedding-3-large produces 3072-dim vectors
OPENAI_EMBEDDING_MODEL=text-embedding-3-large

# Chat model used for GPT reranking and match explanations
# Use gpt-4o-mini in dev (cheaper), gpt-4.1 in production (better quality)
OPENAI_RERANK_MODEL=gpt-4o-mini

# ---------------------------------------------------------------------------
# Application Settings
# ---------------------------------------------------------------------------
# Allowed CORS origins (comma-separated). Set to your frontend URL in production.
CORS_ORIGINS=http://localhost:5173

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# ---------------------------------------------------------------------------
# Rate Limiting
# ---------------------------------------------------------------------------
# Max login attempts per IP per minute
RATE_LIMIT_LOGIN=10/minute

# Max match-run requests per user per hour
RATE_LIMIT_MATCH=30/hour

# ---------------------------------------------------------------------------
# Seeding (development only)
# ---------------------------------------------------------------------------
# Password for the initial admin matchmaker created by scripts/create_matchmaker.py
SEED_ADMIN_PASSWORD=admin123
