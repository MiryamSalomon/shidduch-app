# =============================================================================
# Shidduch Matchmaking System — Git Ignore Rules
# =============================================================================

# ---------------------------------------------------------------------------
# Environment & secrets — NEVER commit these
# ---------------------------------------------------------------------------
.env
.env.local
.env.production
*.pem
*.key

# ---------------------------------------------------------------------------
# Python
# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
.eggs/
*.egg

# Virtual environments
.venv/
venv/
env/

# Type checker / linter caches
.mypy_cache/
.ruff_cache/
.pytest_cache/

# Coverage reports
htmlcov/
.coverage
coverage.xml

# ---------------------------------------------------------------------------
# Node.js / Frontend
# ---------------------------------------------------------------------------
node_modules/
frontend/dist/
frontend/build/
*.tsbuildinfo

# ---------------------------------------------------------------------------
# IDE / Editor
# ---------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ---------------------------------------------------------------------------
# Docker
# ---------------------------------------------------------------------------
docker-compose.override.yml

# ---------------------------------------------------------------------------
# OS
# ---------------------------------------------------------------------------
*.log
